{
  "name": "qr-incheck-frontend",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "build:admin": "npm run build --workspace=@qr-incheck/admin-app",
    "build:employee": "npm run build --workspace=@qr-incheck/employee-app",
    "build:scanner": "npm run build --workspace=@qr-incheck/scanner-app",
    "test": "npm run test --workspaces"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
